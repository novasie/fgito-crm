# FGITO CRM deployment config. Copy to `.env` on the VM and fill in. NEVER commit the real .env.
#   cp .env.example .env

# --- Site / domain (served by your existing host nginx) ---
SITE_NAME=crm.fgito.com

# --- Local port the CRM web container publishes on (your host nginx proxies here) ---
HTTP_PORT=8080

# --- Locally-built image tag (build-on-vm.sh sets this; latest is fine) ---
TAG=latest

# --- Secrets (use strong values; put the REAL values only in .env, never here) ---
DB_PASSWORD=change-me-strong-db-password
ADMIN_PASSWORD=change-me-strong-admin-password
